# ===========================================
# SCAMEATER - Environment Variables
# ===========================================

# ===========================================
# DATABASE
# ===========================================
DB_USER=scameater
DB_PASSWORD=change_me_in_production
DB_NAME=scameater
DB_HOST=db
DB_PORT=5432

# ===========================================
# REDIS
# ===========================================
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@redis:6379/0

# ===========================================
# SEAWEEDFS (S3-compatible object storage for audio)
# ===========================================
SEAWEEDFS_ENDPOINT=http://seaweedfs:9000
SEAWEEDFS_ACCESS_KEY=seaweedfs
SEAWEEDFS_SECRET_KEY=change_me_in_production
SEAWEEDFS_BUCKET=call-recordings

# ===========================================
# ASTERISK VOIP
# ===========================================
ASTERISK_HOST=asterisk
ASTERISK_ARI_USER=honeypot-user
ASTERISK_ARI_PASSWORD=change_me_in_production
ASTERISK_SIP_PORT=5060

# ===========================================
# AUDIOSOCKET (TCP server for Asterisk audio bridge)
# ===========================================
AUDIOSOCKET_PORT=9010

# ===========================================
# ZADARMA SIP TRUNK
# ===========================================
ZADARMA_DID=34871242657
ZADARMA_API_KEY=your_zadarma_api_key
ZADARMA_API_SECRET=your_zadarma_api_secret
ZADARMA_SIP_USER=452669
ZADARMA_SIP_PASSWORD=your_sip_password
ZADARMA_SIP_SERVER=sip.zadarma.com
ZADARMA_PUBLIC_IP=212.227.169.99
ZADARMA_MODE=registration
TELEPHONY_PROVIDER=zadarma

# ===========================================
# DEEPGRAM STT (Speech-to-Text)
# Get key at: https://console.deepgram.com/
# ===========================================
DEEPGRAM_API_KEY=your_deepgram_api_key
DEEPGRAM_MODEL=flux  # Use flux for ultra-low latency voice agents

# ===========================================
# GROQ LLM (Language Model)
# Get key at: https://console.groq.com/
# ===========================================
GROQ_API_KEY=your_groq_api_key
LLM_MODEL=llama-3.1-70b-versatile  # Or llama-3.1-8b-instant for dev

# ===========================================
# CARTESIA TTS (Text-to-Speech)
# Get key at: https://cartesia.ai/
# ===========================================
CARTESIA_API_KEY=your_cartesia_api_key

# ===========================================
# OPENAI (Fallback LLM)
# ===========================================
OPENAI_API_KEY=your_openai_api_key

# ===========================================
# TELEGRAM BOT (Real-time notifications)
# Create bot via @BotFather, get chat_id via @userinfobot
# ===========================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ===========================================
# LANGFUSE (LLM observability - optional)
# ===========================================
LANGFUSE_SECRET_KEY=your_langfuse_secret_key
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_NEXTAUTH_SECRET=change_me_random_string_32_chars
LANGFUSE_SALT=change_me_random_string_32_chars

# ===========================================
# CALL LIMITS
# ===========================================
MAX_CALL_DURATION_MINUTES=90
SILENCE_TIMEOUT_SECONDS=30
MIN_DURATION_FOR_BLACKLIST=120

# ===========================================
# NOTIFICATIONS & ANALYSIS
# ===========================================
TELEGRAM_NOTIFICATIONS=true
AUTO_ANALYSIS=true
AUTO_BLACKLIST_THRESHOLD=0.85

# ===========================================
# RETENTION POLICY (days)
# ===========================================
RETENTION_AUDIO_DAYS=30
RETENTION_TRANSCRIPT_DAYS=90
RETENTION_METADATA_YEARS=2
RETENTION_AUDIT_YEARS=5